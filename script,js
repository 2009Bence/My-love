document.addEventListener("DOMContentLoaded", () => {
    // 1. Írógép effektus a főcímhez
    const text = "Jó reggelt, Szerelmem! ❤️";
    const animatedText = document.getElementById("animatedText");
    let index = 0;

    function typeWriter() {
        if (index < text.length) {
            animatedText.innerHTML += text.charAt(index);
            index++;
            setTimeout(typeWriter, 120); // Betűk közötti sebesség (ms)
        }
    }

    // Kis késleltetéssel indítjuk a gépelést, amíg a nap emelkedni kezd
    setTimeout(typeWriter, 1500);

    // 2. Folyamatosan repülő rózsák generálása
    const container = document.getElementById("roseContainer");
    const symbols = ['🌹', '🌸', '🌷'];

    function createPetal() {
        const petal = document.createElement("div");
        petal.classList.add("petal");
        
        // Véletlenszerű virág kiválasztása
        petal.innerText = symbols[Math.floor(Math.random() * symbols.length)];
        
        // Véletlenszerű kezdőpozíció (vízszintesen a képernyő alján)
        petal.style.left = Math.random() * 100 + "vw";
        
        // Véletlenszerű méret
        const size = Math.random() * 20 + 20; // 20px és 40px között
        petal.style.fontSize = `${size}px`;
        
        // Véletlenszerű sebesség és késleltetés az organikus hatásért
        const duration = Math.random() * 5 + 6; // 6-11 másodperc között repülnek fel
        petal.style.animationDuration = `${duration}s`;
        
        container.appendChild(petal);

        // Miután kifutott a képernyőből, töröljük, hogy ne terhelje a memóriát
        setTimeout(() => {
            petal.remove();
        }, duration * 1000);
    }

    // Első adag szirmok azonnali indítása
    for(let i = 0; i < 15; i++) {
        setTimeout(createPetal, Math.random() * 3000);
    }

    // Folyamatos utánpótlás időközönként
    setInterval(createPetal, 600);
});
